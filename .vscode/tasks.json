{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FPGA: Tool Versions",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile tools",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Detect",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile detect",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Lint (Verilator)",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile lint",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": {
        "owner": "verilator",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^%(Error|Warning)(-\\w+)?: (.+?):(\\d+):(\\d+): (.+)$",
          "severity": 1,
          "file": 3,
          "line": 4,
          "column": 5,
          "message": 6
        }
      }
    },
    {
      "label": "FPGA: Simulate",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile sim TB=${input:testbench}",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": {
        "owner": "iverilog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?):(\\d+): (error|warning): (.+)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    },
    {
      "label": "FPGA: View Waveform",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile wave",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Schematic (SVG)",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile schematic",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Check (lint + sim)",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile check TB=${input:testbench}",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Build (.fs)",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": {
        "owner": "yosys",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?):(\\d+): (ERROR|Warning): (.+)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    },
    {
      "label": "FPGA: Program",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile program",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: PnR (GOWIN CLI)",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile pnr-gowin",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Compare flows (nextpnr vs GOWIN)",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile compare",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "FPGA: Clean",
      "type": "shell",
      "command": "make -f ${workspaceFolder}/Makefile clean",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "testbench",
      "description": "Testbench name (without .v extension, e.g. tb_traffic_pack)",
      "type": "promptString",
      "default": "tb_traffic_pack"
    }
  ]
}
